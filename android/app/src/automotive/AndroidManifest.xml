<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cenkt.music_player">

    <!-- Declare the app runs on Android Automotive OS devices -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="true" />

    <application>
        <!-- AAOS CarAppService – only in automotive flavor to avoid Play Store mutual-exclusion error -->
        <service
            android:name="com.cenkt.music_player.car.MusicCarService"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
            </intent-filter>
        </service>
    </application>
</manifest>